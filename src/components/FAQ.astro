const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a,
    },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<section id="faq" class="bg-canvas-soft py-24">
  <div class="mx-auto max-w-[720px] px-6">
    <div class="text-center">
      <span class="font-mono text-xs uppercase tracking-wide text-mute">FAQ</span>
      <h2 class="mt-3 text-3xl font-semibold tracking-[-1.28px] text-ink md:text-4xl">
        Frequently asked questions.
      </h2>
    </div>

    <div class="mt-12 divide-y divide-hairline">
      {faqs.map((faq) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer items-center justify-between text-base font-medium text-ink">
            <span>{faq.q}</span>
            <svg class="h-5 w-5 shrink-0 text-mute transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M12 4.5v15m7.5-7.5h-15" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-body">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
