---
---

<section class="relative overflow-hidden bg-canvas pb-24 pt-32">
  <!-- Mesh gradient backdrop -->
  <div class="pointer-events-none absolute inset-0 -top-32 opacity-30">
    <div class="absolute left-1/4 top-0 h-[500px] w-[500px] rounded-full bg-[#007cf0] blur-[120px]"></div>
    <div class="absolute right-1/4 top-12 h-[400px] w-[400px] rounded-full bg-[#00dfd8] blur-[120px]"></div>
    <div class="absolute left-1/2 top-24 h-[350px] w-[350px] -translate-x-1/2 rounded-full bg-[#7928ca] blur-[120px]"></div>
    <div class="absolute right-1/3 top-8 h-[300px] w-[300px] rounded-full bg-[#ff0080] blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-[1400px] px-6 text-center">
    <div class="mx-auto inline-flex items-center gap-2 rounded-full bg-canvas-soft-2 px-3 py-1 text-xs font-normal text-body">
      <span class="font-mono">100% free</span>
      <span class="text-hairline-strong">·</span>
      <span class="font-mono">No signup required</span>
    </div>

    <h1 class="mx-auto mt-6 max-w-3xl text-5xl font-semibold leading-[1] tracking-[-2.4px] text-ink md:text-6xl">
      Check your cold emails for spam words.
    </h1>

    <p class="mx-auto mt-5 max-w-xl text-lg leading-7 text-body">
      Scan your email templates instantly. Get a deliverability score, categorized warnings, and smart suggestions to land in the inbox.
    </p>

    <div class="mt-8 flex items-center justify-center gap-3">
      <a href="#checker" class="inline-flex h-12 items-center rounded-[100px] bg-primary px-5 text-base font-medium text-on-primary transition-opacity hover:opacity-90">
        Start Scanning
      </a>
      <a href="#features" class="inline-flex h-12 items-center rounded-[100px] border border-hairline bg-canvas px-5 text-base font-medium text-ink transition-colors hover:bg-canvas-soft-2">
        How It Works
      </a>
    </div>

    <nav class="mt-8 flex flex-wrap items-center justify-center gap-4 text-sm text-body">
      <a href="/about" class="transition-colors hover:text-ink">About Us</a>
      <span class="text-hairline-strong">·</span>
      <a href="/privacy" class="transition-colors hover:text-ink">Privacy Policy</a>
      <span class="text-hairline-strong">·</span>
      <a href="/terms" class="transition-colors hover:text-ink">Terms & Conditions</a>
      <span class="text-hairline-strong">·</span>
      <a href="/contact" class="transition-colors hover:text-ink">Contact Us</a>
    </nav>
  </div>
</section>
