---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Terms & Conditions — Cold Email Checker"
  description="Terms and Conditions for using Cold Email Checker. Read our terms of service before using our free email spam checker tool."
  keywords="terms and conditions, terms of service, cold email checker terms"
>
  <Navbar />
  <main class="mx-auto max-w-3xl px-6 py-16">
    <h1 class="text-3xl font-semibold text-ink">Terms & Conditions</h1>
    <p class="mt-2 text-sm text-mute">Last updated: June 8, 2026</p>

    <div class="mt-10 space-y-8 text-body leading-relaxed">
      <section>
        <h2 class="text-lg font-medium text-ink">1. Acceptance of Terms</h2>
        <p class="mt-2">By accessing and using Cold Email Checker (coldemailchecker.com), you agree to be bound by these Terms & Conditions. If you do not agree, please do not use the service.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">2. Service Description</h2>
        <p class="mt-2">Cold Email Checker provides a free, browser-based tool that analyzes email content for spam trigger words. The tool provides suggestions only and does not guarantee email deliverability.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">3. Acceptable Use</h2>
        <p class="mt-2">You agree to use Cold Email Checker only for lawful purposes. You must not use our tool to:</p>
        <ul class="mt-2 list-disc pl-6 space-y-1">
          <li>Craft emails intended for phishing, fraud, or harassment</li>
          <li>Send unsolicited bulk email in violation of anti-spam laws</li>
          <li>Attempt to disrupt or exploit the service</li>
        </ul>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">4. Disclaimer of Warranties</h2>
        <p class="mt-2">The service is provided "as is" without warranties of any kind. We do not guarantee that using our tool will result in your emails reaching recipients' inboxes.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">5. Limitation of Liability</h2>
        <p class="mt-2">Cold Email Checker shall not be liable for any indirect, incidental, or consequential damages arising from your use of the service.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">6. Intellectual Property</h2>
        <p class="mt-2">All content, branding, and code on this website are the property of Cold Email Checker. You may not reproduce or redistribute any part of the service without permission.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">7. Changes to Terms</h2>
        <p class="mt-2">We reserve the right to modify these terms at any time. Continued use of the service after changes constitutes acceptance of the updated terms.</p>
      </section>

      <section>
        <h2 class="text-lg font-medium text-ink">8. Contact</h2>
        <p class="mt-2">For questions about these terms, <a href="/contact" class="text-ink underline">contact us here</a>.</p>
      </section>
    </div>
  </main>
  <Footer />
</Layout>
